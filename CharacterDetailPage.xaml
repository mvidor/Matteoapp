<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MatteoAPP1.ViewModels"
             x:Class="MatteoAPP1.CharacterDetailPage"
             x:DataType="vm:CharacterDetailViewModel"
             BackgroundColor="#FCFBF8"
             Title="Detail">

    <ScrollView>
        <VerticalStackLayout Padding="28,32,28,24" Spacing="18">
            <Label
                Text="DETAIL"
                FontSize="13"
                CharacterSpacing="3"
                TextColor="#9F1239" />

            <Border
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                BackgroundColor="White"
                Padding="14">
                <Grid>
                    <Image
                        Source="{Binding DisplayImageSource}"
                        HeightRequest="260"
                        Aspect="AspectFit"
                        IsVisible="{Binding HasImage}" />

                    <Image
                        Source="characters_tab.svg"
                        HeightRequest="72"
                        WidthRequest="72"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasNoImage}" />
                </Grid>
            </Border>

            <Label
                Text="{Binding Name}"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="#111827" />

            <Label
                Text="{Binding Description}"
                FontSize="16"
                TextColor="#4B5563" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
