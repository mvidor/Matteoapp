<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MatteoAPP1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MatteoAPP1"
    Title="Demon Slayer"
    Shell.TabBarBackgroundColor="#FFFFFF"
    Shell.TabBarForegroundColor="#111827"
    Shell.TabBarTitleColor="#111827"
    Shell.TabBarUnselectedColor="#6B7280">

    <TabBar>
        <ShellContent
            Title="Accueil"
            Icon="home_tab.svg"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Perso"
            Icon="characters_tab.svg"
            ContentTemplate="{DataTemplate local:CharactersPage}"
            Route="CharactersPage" />

        <ShellContent
            Title="Ajouter"
            Icon="gallery_tab.svg"
            ContentTemplate="{DataTemplate local:GalleryPage}"
            Route="GalleryPage" />

        <ShellContent
            Title="Note"
            Icon="movie_tab.svg"
            ContentTemplate="{DataTemplate local:MoviePage}"
            Route="MoviePage" />
    </TabBar>

</Shell>
