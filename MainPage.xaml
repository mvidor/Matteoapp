<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MatteoAPP1.MainPage"
             Title="Accueil">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="180"
                Aspect="AspectFit"
                SemanticProperties.Description="Illustration de presentation Demon Slayer" />

            <Label
                Text="Demon Slayer"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="#111827"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Application MAUI consacree au dernier film sorti."
                FontSize="18"
                TextColor="#4B5563"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Presentation de l application Demon Slayer" />

            <Frame
                BackgroundColor="#BE123C"
                CornerRadius="20"
                Padding="20"
                HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Bienvenue dans l'univers de Tanjiro"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />
                    <Label
                        Text="Utilise les 4 onglets pour naviguer entre l'accueil, le film, les personnages et la galerie."
                        FontSize="16"
                        TextColor="#FFE4E6" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
