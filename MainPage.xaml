<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MatteoAPP1"
             x:Class="MatteoAPP1.MainPage"
             x:DataType="local:MainPage"
             BackgroundColor="#FCFBF8"
             Title="Accueil">

    <ScrollView>
        <VerticalStackLayout Padding="28,32,28,24" Spacing="22">
            <Label
                Text="Demon Slayer"
                FontSize="38"
                FontAttributes="Bold"
                TextColor="#111827"
                HorizontalOptions="Center"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Presentation de l'univers de Demon Slayer"
                FontSize="17"
                TextColor="#6B7280"
                HorizontalTextAlignment="Center"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Sous titre de la page d accueil Demon Slayer" />

            <Border
                Stroke="#E5E7EB"
                StrokeThickness="1"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 24"
                Padding="12">
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        WidthRequest="150"
                        HeightRequest="214"
                        BackgroundColor="#F9FAFB">
                        <Image
                            Source="tanjiro.webp"
                            Aspect="AspectFill"
                            SemanticProperties.Description="Image de Tanjiro Kamado" />
                    </Border>

                    <Border
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        WidthRequest="150"
                        HeightRequest="214"
                        BackgroundColor="#F9FAFB">
                        <Image
                            Source="nezuko.jpg"
                            Aspect="AspectFill"
                            SemanticProperties.Description="Image de Nezuko Kamado" />
                    </Border>
                </HorizontalStackLayout>
            </Border>

            <Button
                Text="Voir la scene animee"
                Clicked="OnGifButtonClicked"
                BackgroundColor="#111827"
                TextColor="White"
                CornerRadius="16"
                Padding="18,14" />

            <CarouselView
                HeightRequest="176"
                PeekAreaInsets="18"
                ItemsSource="{Binding Slides}"
                IndicatorView="SlidesIndicator">
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="local:HomeSlide">
                        <Border
                            Margin="0,0,0,8"
                            Padding="18"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 22"
                            BackgroundColor="{Binding CardColor}">
                            <Grid ColumnDefinitions="72,*" ColumnSpacing="14">
                                <Border
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="White">
                                    <Image
                                        Source="{Binding ImageSource}"
                                        HeightRequest="72"
                                        WidthRequest="72"
                                        Aspect="AspectFit" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Label
                                        Text="{Binding Title}"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        TextColor="#111827" />
                                    <Label
                                        Text="{Binding Description}"
                                        FontSize="14"
                                        TextColor="#4B5563" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <IndicatorView
                x:Name="SlidesIndicator"
                HorizontalOptions="Center"
                IndicatorColor="#D1D5DB"
                SelectedIndicatorColor="#111827" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
