<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MatteoAPP1.GalleryPage"
             Title="Galerie">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Galerie"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111827" />

            <Frame BackgroundColor="#7C3AED"
                   CornerRadius="18"
                   Padding="18"
                   HasShadow="False">
                <Label Text="Cet onglet servira pour les affiches, captures ou illustrations autour de Demon Slayer."
                       FontSize="16"
                       TextColor="White" />
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
