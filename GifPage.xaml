<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MatteoAPP1.GifPage"
             BackgroundColor="#FCFBF8"
             Title="GIF">

    <ScrollView>
        <VerticalStackLayout Padding="28,32,28,24" Spacing="20">
            <Label
                Text="SCENE"
                FontSize="13"
                CharacterSpacing="3"
                TextColor="#9F1239"
                HorizontalOptions="Center" />

            <Label
                Text="Scene animee"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="#111827"
                HorizontalOptions="Center" />

            <Label
                Text="Le GIF tourne quelques secondes, puis le retour a l'accueil devient disponible."
                FontSize="16"
                TextColor="#6B7280"
                HorizontalTextAlignment="Center" />

            <Border
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="10"
                BackgroundColor="White">
                <toolkit:MediaElement
                    Source="demon_slayer_scene.mp4"
                    HeightRequest="240"
                    Aspect="AspectFit"
                    ShouldAutoPlay="True"
                    ShouldShowPlaybackControls="True" />
            </Border>

            <Label
                x:Name="StatusLabel"
                Text="Lecture du GIF en cours..."
                FontSize="15"
                TextColor="#6B7280"
                HorizontalOptions="Center" />

            <Button
                x:Name="BackButton"
                Text="Retour a l'accueil"
                Clicked="OnBackClicked"
                IsEnabled="False"
                BackgroundColor="#111827"
                TextColor="White"
                CornerRadius="16"
                Padding="18,14" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
